.card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px}
.sec-label{font-family:'Syne',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--pink);margin:20px 0 10px;padding-bottom:7px;border-bottom:1px solid var(--border)}
.sec-label:first-child{margin-top:0}
.fg{margin-bottom:14px}
label{display:block;font-size:.8rem;color:var(--muted);margin-bottom:5px}
.req{color:var(--pink)}
input,textarea,select{width:100%;background:var(--surface);border:1.5px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.9rem;outline:none;transition:border-color .2s;resize:none}
input:focus,textarea:focus,select:focus{border-color:var(--pink)}
textarea{min-height:90px}
select option{background:var(--surface)}
