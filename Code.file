       <!--describing all colours available in css to add in websites and it is global-->
       <style>:root {
  --bg:       #080810;  
  --surface:  #10101a;
  --card:     #14141f;
  --border:   #222233;
  --lime:     #c8f55a;
  --purple:   #7c6af7;
  --pink:     #f55a8f;
  --text:     #f0f0f8;
  --muted:    #7777a0;
  --faint:    #333355;
  --head:     'Syne', sans-serif;
  --body:     'DM Sans', sans-serif;
  --radius:   16px;
}
/*This will decide the scroll behaviour of the website*/
html { scroll-behavior: smooth; }  
/*adding body colors and deciding shades*/
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  overflow-x: hidden;
  cursor: none;
}

/*Adding the information about the cursor that what should be the color and size width*/
.cursor {
  width: 10px; height: 10px;
  background: var(--lime);
  border-radius: 50%;
  position: fixed;
  top: 0; left: 0;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s, width 0.2s, height 0.2s;
  transform: translate(-50%,-50%);
}
.cursor.big { width: 36px; height: 36px; opacity: 0.3; }
 <!--This is a invisible gradient on the website that means you can see the cursor moving but no click be done-->
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
  opacity: 0.5;
}
/*Background mein kuch coloured circles dega jo blur honge unhe move karta rahega*/
.orb {
  position: fixed;
  border-radius: 50%;
  filter: blur(100px);
  pointer-events: none;
  z-index: 0;
  animation: drift 12s ease-in-out infinite alternate;
}
.orb-1 { width:500px;height:500px;background:var(--purple);opacity:.12;top:-150px;left:-150px;animation-delay:0s; }
.orb-2 { width:400px;height:400px;background:var(--pink);opacity:.10;bottom:-100px;right:-100px;animation-delay:3s; }
.orb-3 { width:300px;height:300px;background:var(--lime);opacity:.06;top:40%;left:35%;animation-delay:6s; }
@keyframes drift {
  0%   { transform: translate(0,0) scale(1); }
  100% { transform: translate(40px,30px) scale(1.15); }
}

/* SETTING THE NAVBAR COLOR,SIDE AND CLICKABLE FILTERS*/
        nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 60px;
  background: rgba(8,8,16,0.7);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  animation: fadeDown 0.7s ease backwards;
}
@keyframes fadeDown {
  from { opacity:0; transform:translateY(-20px); }
  to   { opacity:1; transform:translateY(0); }
}
/*ADDING NAVBAR LOGO IN WEBSITE*/
.nav-logo {
  font-family: var(--head);
  font-size: 1.5rem;
  font-weight: 800;
  letter-spacing: -1px;
  text-decoration: none;
  color: var(--text);
}
.nav-logo span { color: var(--lime); }
 
.nav-links {
  display: flex;
  gap: 36px;
  list-style: none;
}
.nav-links a {
  color: var(--muted);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 500;
  transition: color 0.2s;
  position: relative;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0; right: 0;
  height: 2px;
  background: var(--lime);
  transform: scaleX(0);
  transition: transform 0.25s;
}
/* changes in the link on navbar if mouse hover on it*/
.nav-links a:hover { color: var(--text); }
.nav-links a:hover::after { transform: scaleX(1); }
 
.nav-cta {
  display: flex;
  gap: 12px;
  align-items: center;
}
/* STYKING THE BUTTON IN THE HRTML CLASS*/
.btn-ghost {
  padding: 9px 22px;
  border: 1.5px solid var(--border);
  border-radius: 50px;
  color: var(--muted);
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 500;
  transition: all 0.2s;
}
.btn-ghost:hover { border-color: var(--lime); color: var(--lime); }
.btn-solid {
  padding: 9px 22px;
  background: var(--lime);
  border-radius: 50px;
  color: #080810;
  text-decoration: none;
  font-family: var(--head);
  font-size: 0.88rem;
  font-weight: 700;
  transition: all 0.2s;
}
.btn-solid:hover { background: #d9ff70; transform: translateY(-1px); }
 /* THREE LINES THAT WILL BE SHOWN ON MOBILE VIEW NOT ON DESKTOP FOR NAVBAR*/
.hamburger { display:none; flex-direction:column; gap:5px; cursor:pointer; }
.hamburger span { width:24px;height:2px;background:var(--text);border-radius:2px;transition:all 0.3s; }
/*MAIN SECTION OF THE WEBSITE WHICH WILL SHOW VERY FIRST IN THE VIEW OF USER*/
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 120px 24px 80px;
  position: relative;
  z-index: 1;
}
.hero-inner { max-width: 820px; }
 
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(200,245,90,0.08);
  border: 1px solid rgba(200,245,90,0.2);
  color: var(--lime);
  font-size: 0.8rem;
  font-weight: 500;
  padding: 6px 16px;
  border-radius: 50px;
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.6s 0.3s ease forwards;
  letter-spacing: 0.05em;
}
.hero-badge .dot {
  width: 6px; height: 6px;
  background: var(--lime);
  border-radius: 50%;
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { opacity:1; transform:scale(1); }
  50%      { opacity:0.4; transform:scale(1.4); }
}

.hero h1 {
  font-family: var(--head);
  font-size: clamp(3rem, 7vw, 5.5rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -3px;
  margin-bottom: 24px;
  opacity: 0;
  animation: fadeUp 0.7s 0.5s ease forwards;
}
.hero h1 em {
  font-style: normal;
  color: var(--lime);
  position: relative;
}
.hero h1 em::after {
  content: '';
  position: absolute;
  left: 0; bottom: 4px; right: 0;
  height: 4px;
  background: var(--lime);
  opacity: 0.3;
  border-radius: 2px;
}
 
.hero p {
  color: var(--muted);
  font-size: 1.15rem;
  line-height: 1.7;
  max-width: 560px;
  margin: 0 auto 40px;
  opacity: 0;
  animation: fadeUp 0.7s 0.7s ease forwards;
}
 /* SETTING OF BUTTONS THAT WILL DISPLAY WHEN YOU SCROLL THE WEBSITE*/
.hero-btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s 0.9s ease forwards;
}
.hero-btns .btn-primary {
  padding: 16px 36px;
  background: var(--lime);
  color: #080810;
  border-radius: 50px;
  font-family: var(--head);
  font-size: 1rem;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.25s;
}
.hero-btns .btn-primary:hover {
  background: #d9ff70;
  transform: translateY(-3px);
  box-shadow: 0 16px 40px rgba(200,245,90,0.25);
}
.hero-btns .btn-outline {
  padding: 16px 36px;
  border: 1.5px solid var(--border);
  color: var(--text);
  border-radius: 50px;
  font-size: 1rem;
  text-decoration: none;
  transition: all 0.25s;
}
.hero-btns .btn-outline:hover { border-color: var(--lime); color: var(--lime); }
 
/* SCROLL INDICATION WHILE SCROLLING DOWN*/
.scroll-hint {
  position: absolute;
  bottom: 36px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: var(--muted);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  opacity: 0;
  animation: fadeUp 0.6s 1.4s ease forwards;
}
.scroll-hint .arrow {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--muted), transparent);
  animation: scrollDrop 1.5s ease-in-out infinite;
}
@keyframes scrollDrop {
  0%,100% { opacity:0; transform:scaleY(0); transform-origin:top; }
  50%      { opacity:1; transform:scaleY(1); }
}
 
/* THIS IS STATS BAR SHOWING THE ENGAGEMENT OF THE PEOPLE */
.stats-bar {
  position: relative; z-index: 1;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  display: flex;
  justify-content: center;
  gap: 0;
  overflow: hidden;
}
.stat-item {
  flex: 1;
  max-width: 260px;
  text-align: center;
  padding: 36px 24px;
  border-right: 1px solid var(--border);
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s, transform 0.5s;
}
.stat-item:last-child { border-right: none; }
.stat-item.visible { opacity:1; transform:translateY(0); }
.stat-num {
  font-family: var(--head);
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--lime);
  letter-spacing: -2px;
}
.stat-label {
  color: var(--muted);
  font-size: 0.85rem;
  margin-top: 4px;
}
 
/* THIS IS SECTION PART OF THE WEBSITE WHICH WILL DEFINE AND TELL ABOUT THE SITE AND ITS FEATURE*/
section { position: relative; z-index: 1; }
.section-label {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--lime);
  margin-bottom: 14px;
}
.section-title {
  font-family: var(--head);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  letter-spacing: -1.5px;
  line-height: 1.1;
  margin-bottom: 16px;
}
.section-sub {
  color: var(--muted);
  font-size: 1rem;
  line-height: 1.7;
  max-width: 520px;
}
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.65s ease, transform 0.65s ease;
}
.reveal.visible { opacity:1; transform:translateY(0); }
 
/*THIS IS SERVICES HEAD PROVIDED BY US IN THE WEBSITE*/
.services {
  padding: 100px 60px;
}
.services-head {
  text-align: center;
  margin-bottom: 64px;
}
.services-head .section-sub { margin: 0 auto; }
.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1100px;
  margin: 0 auto;
}
.service-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 36px 32px;
  transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  cursor: default;
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.5s, transform 0.5s, border-color 0.3s, box-shadow 0.3s;
}
.service-card.visible { opacity:1; transform:translateY(0); }
.service-card:hover {
  border-color: var(--lime);
  box-shadow: 0 0 40px rgba(200,245,90,0.07);
  transform: translateY(-4px) !important;
}
.card-icon {
  width: 52px; height: 52px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
  margin-bottom: 22px;
}
/*THIS ICON CIRCLE IN DIFFERENT COLORS*/
.card-icon.green  { background: rgba(200,245,90,0.1); }
.card-icon.purple { background: rgba(124,106,247,0.1); }
.card-icon.pink   { background: rgba(245,90,143,0.1); }
.card-icon.blue   { background: rgba(90,180,245,0.1); }
.service-card h3 {
  font-family: var(--head);
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 10px;
}
.service-card p {
