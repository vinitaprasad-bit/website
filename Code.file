                    <label>How do you struggle?</label>
                    <textarea name="weaknesses" placeholder="e.g. Procrastination, nervousness, focus..."><?= isset($_POST['weaknesses'])?htmlspecialchars($_POST['weaknesses']??''):'' ?></textarea>
                </div>
                <div class="sec-label">Your Confusions – Most Important!</div>
                <div class="fg">
                    <label>Exactly what is confusing?</label>
                    <textarea name="confusion" placeholder="e.g. Should I take science or commerce? Parents are forcing me...."><?= isset($_POST['confusion'])?htmlspecialchars($_POST['confusion']??''):'' ?></textarea>
                    <p class="hint">💬 This field gives the most accurate advice.</p>
                </div>
                <button type="submit" class="btn-submit">🎯 Give me guidance →</button>
            </form>
        </div>
        <?php endif; ?>
    </div>
 
    <div class="sidebar">
        <div class="s-card">
            <h3>💡 Tips</h3>
            <ul class="tips">
                <li><span>✍️</span> Write the truth – there will be no judgement</li>
                <li><span>📝</span>Write in detail = better advice</li>
                <li><span>💾</span> Advice auto-save </li>
                <li><span>🔄</span>Can fill many times</li>
                <li><span>🏠</span> <a href="index.php">Go back to home</a></li>
            </ul>
        </div>
        <div class="s-card">
            <h3>📂  Past Guidance</h3>
            <?php if (mysqli_num_rows($past) > 0): ?>
                <?php while ($r = mysqli_fetch_assoc($past)): ?>
                <div class="past-item">
                    <div class="p-date"><?= date('d M Y, h:i A', strtotime($r['created_at'])) ?></div>
                    <div class="p-dream">🎯 <?= htmlspecialchars($r['dream_career']) ?></div>
                    <div class="p-snip"><?= htmlspecialchars(substr(strip_tags($r['advice_given']), 0, 90)) ?>...</div>
                </div>
                <?php endwhile; ?>
            <?php else: ?>
                <p style="color:var(--muted);font-size:.82rem;line-height:1.6">Abhi koi guidance nahi. Pehla form fill karo! 🌱</p>
            <?php endif; ?>
        </div>
    </div>
</div>
 
</body>
</html>
 
