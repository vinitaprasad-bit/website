<style>
  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --card: #1a1a24;
    --border: #2a2a3a;
    --accent1: #c8f55a;
    --accent2: #7c6af7;
    --accent3: #f55a8f;
    --text: #f0f0f5;
    --muted: #8888a0;
    --font-head: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }
 
  * { margin: 0; padding: 0; box-sizing: border-box; }
 
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
 
  /* Animated background blobs */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.18;
    animation: blobMove 8s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }
  .blob-1 { width: 500px; height: 500px; background: var(--accent2); top: -100px; left: -100px; animation-delay: 0s; }
  .blob-2 { width: 400px; height: 400px; background: var(--accent3); bottom: -80px; right: -80px; animation-delay: 2s; }
  .blob-3 { width: 300px; height: 300px; background: var(--accent1); top: 40%; left: 40%; animation-delay: 4s; }
 
  @keyframes blobMove {
    0%   { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, 20px) scale(1.1); }
  }
 
  .wrapper {
    display: flex;
    width: 100%;
    max-width: 900px;
    min-height: 560px;
    z-index: 1;
    padding: 20px;
    gap: 0;
  }
 
  /* Left branding panel */
  .brand-panel {
    flex: 1;
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    border-radius: 24px 0 0 24px;
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--border);
    border-right: none;
    position: relative;
    overflow: hidden;
  }
  .brand-panel::before {
    content: '';
    position: absolute;
    top: -60px; left: -60px;
    width: 200px; height: 200px;
    background: var(--accent2);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.3;
  }
 
  .logo {
    font-family: var(--font-head);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -1px;
  }
  .logo span { color: var(--accent1); }
 
  .brand-tagline {
    font-size: 2.2rem;
    font-family: var(--font-head);
    font-weight: 700;
    line-height: 1.2;
    margin-top: auto;
  }
  .brand-tagline em {
    font-style: normal;
    color: var(--accent1);
  }
 
  .brand-sub {
    color: var(--muted);
    font-size: 0.95rem;
    margin-top: 12px;
    line-height: 1.6;
  }
 
  .pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 24px;
  }
  .pill {
    background: rgba(124,106,247,0.15);
    border: 1px solid rgba(124,106,247,0.3);
    color: #a99af5;
    font-size: 0.78rem;
    padding: 6px 14px;
    border-radius: 50px;
    font-family: var(--font-body);
  }
 
  /* Right form panel */
  .form-panel {
    flex: 1;
    background: var(--card);
    border-radius: 0 24px 24px 0;
    padding: 48px 40px;
    border: 1px solid var(--border);
    border-left: none;
    overflow-y: auto;
  }
 
  .tabs {
    display: flex;
    gap: 0;
    margin-bottom: 32px;
    background: var(--surface);
    border-radius: 12px;
    padding: 4px;
  }
  .tab {
    flex: 1;
    text-align: center;
    padding: 10px;
    border-radius: 9px;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.25s;
    color: var(--muted);
    text-decoration: none;
  }
  .tab.active {
    background: var(--accent1);
    color: #0a0a0f;
  }
 
