  color: var(--text);
}
.mock-result span { color: var(--lime); font-weight: 600; }
 
/*THIS IS TESTIMONIALS OF MY SITE WHO USED IT */
.testimonials {
  padding: 100px 60px;
}
.testimonials-head { text-align:center; margin-bottom:60px; }
.testimonials-head .section-sub { margin:0 auto; }
.testi-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  max-width: 1100px;
  margin: 0 auto;
}
.testi-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 30px;
  opacity: 0;
  transform: translateY(20px);
