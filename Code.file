.type-pill:hover{border-color:var(--pink);color:var(--pink)}
.type-pill.selected{background:rgba(245,90,143,.1);border-color:var(--pink);color:var(--pink)}
.sidebar{display:flex;flex-direction:column;gap:16px}
.s-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px}
.s-card h3{font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:12px}
.tips{list-style:none;display:flex;flex-direction:column;gap:8px}
