<?php
// auth.php — SoulSpace Login & Register Page
session_start();
require_once 'db.php';
 
$errors = [];
$success = "";
$mode = isset($_GET['mode']) ? $_GET['mode'] : 'login';
 
// ─── REGISTER ───────────────────────────────────────────────
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['register'])) {
    $full_name = trim(mysqli_real_escape_string($conn, $_POST['full_name']));
    $username  = trim(mysqli_real_escape_string($conn, $_POST['username']));
    $email     = trim(mysqli_real_escape_string($conn, $_POST['email']));
    $password  = $_POST['password'];
    $age       = intval($_POST['age']);
 
    if (empty($full_name) || empty($username) || empty($email) || empty($password))
        $errors[] = "Fill all the feilds!";
    if (!filter_var($email, FILTER_VALIDATE_EMAIL))
        $errors[] = "Email should be valid.";
    if (strlen($password) < 6)
        $errors[] = "Password should be atleast of 6 characters.";
 
    if (empty($errors)) {
        // Check duplicate
        $check = mysqli_query($conn, "SELECT id FROM users WHERE email='$email' OR username='$username'");
       if ($check && mysqli_num_rows($check) > 0) {
            $errors[] = "Email or username is already registered!";
        } else {
            $hashed = password_hash($password, PASSWORD_DEFAULT);
            $sql = "INSERT INTO users (full_name, username, email, password, age)
                    VALUES ('$full_name','$username','$email','$hashed','$age')";
            if (mysqli_query($conn, $sql)) {
    $success = "Your account has been made. Please login 🎉";
    $mode = 'login';
} else {
    die("SQL Error: " . mysqli_error($conn));
}
        }
    }
}
 
// ─── LOGIN ───────────────────────────────────────────────────
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['login'])) {
    $email    = trim(mysqli_real_escape_string($conn, $_POST['email']));
    $password = $_POST['password'];
 
    if (empty($email) || empty($password)) {
        $errors[] = "Enter email and password both!";
    } else {
        $res = mysqli_query($conn, "SELECT * FROM users WHERE email='$email'");
        if ($res && mysqli_num_rows($res) === 1) {
            $user = mysqli_fetch_assoc($res);
            if (password_verify($password, $user['password'])) {
                $_SESSION['user_id']   = $user['id'];
                $_SESSION['username']  = $user['username'];
                $_SESSION['full_name'] = $user['full_name'];
                header("Location: index.php");
                exit;
            } else {
                $errors[] = "Password is wrong!";
            }
        } else {
            $errors[] = "Email is not registered.";
        }
    }
}
?>
