.err{background:rgba(245,90,143,.08);border:1px solid rgba(245,90,143,.25);color:var(--pink);border-radius:10px;padding:10px 14px;font-size:.85rem;margin-bottom:14px}
.btn-submit{width:100%;padding:14px;background:var(--pink);color:#fff;border:none;border-radius:12px;font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;margin-top:6px;transition:all .2s}
.btn-submit:hover{background:#f77aaa}
.btn-again{background:transparent;border:1.5px solid var(--border);color:var(--muted);padding:8px 20px;border-radius:50px;cursor:pointer;font-size:.83rem;margin-bottom:20px;transition:all .2s;font-family:'DM Sans',sans-serif}
.btn-again:hover{border-color:var(--pink);color:var(--pink)}
.result-card{background:linear-gradient(135deg,rgba(245,90,143,.05),rgba(124,106,247,.05));border:1px solid rgba(245,90,143,.2);border-radius:20px;padding:28px;margin-bottom:22px}
.result-top{display:flex;align-items:center;gap:10px;margin-bottom:16px}
