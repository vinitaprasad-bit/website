.btn-xs:hover{border-color:var(--lime);color:var(--lime)}
.wrap{max-width:1060px;margin:0 auto;padding:110px 50px 70px;display:grid;grid-template-columns:1fr 320px;gap:24px;align-items:start}
h1{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;letter-spacing:-1.5px;margin-bottom:8px}
h1 em{font-style:normal;color:var(--pink)}
