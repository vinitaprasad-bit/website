<?php
// ── SESSION + AUTH ────────────────────────────────────────
session_start();
if (!isset($_SESSION['user_id'])) {
    header("Location: auth.php?mode=login");
    exit;
}
 
// ── DATABASE — include se connect ─────────────────────────
$conn = include 'db.php';
 
$user_id   = (int)$_SESSION['user_id'];
$full_name = htmlspecialchars($_SESSION['full_name']);
$advice    = "";
$submitted = false;
$errors    = [];
 
// ── HELPER ────────────────────────────────────────────────
function has($text, $word) {
    return strpos(strtolower($text), $word) !== false;
}
 
// ── ADVICE ENGINE ─────────────────────────────────────────
function generateAdvice($class, $interests, $strengths, $weaknesses, $dream, $confusion) {
    $i   = $interests . ' ' . $dream;
    $out = "";
 
    if (has($i,'coding') || has($i,'software') || has($i,'tech') || has($i,'web') || has($i,'app') || has($i,'computer'))
        $out .= "💻 <strong>Tech Path:</strong> I see you're interested in technology! Try software development or web development. Get started with HTML, CSS, and JS at freeCodeCamp.org—it's free. Create a project and upload it to GitHub.<br><br>";
 
    elseif (has($i,'design') || has($i,'art') || has($i,'drawing') || has($i,'graphic') || has($i,'creative') || has($i,'animation'))
        $out .= "🎨 <strong>Creative Path:</strong> Creativity is your superpower! There's so much scope in UI/UX or graphic design. Download Figma today—the free tool the professionals use.
<br><br>";
 
    elseif (has($i,'doctor') || has($i,'medical') || has($i,'neet') || has($i,'biology') || has($i,'health') || has($i,'mbbs'))
        $out .= "🏥 <strong>Medical Path:</strong> Becoming a doctor is a noble choice! Study NCERT Biology and Chemistry daily for NEET. Consistency is key—6-8 hours of consistent study daily can help you crack NEET.<br><br>";
 
    elseif (has($i,'business') || has($i,'entrepreneur') || has($i,'marketing') || has($i,'startup') || has($i,'commerce'))
        $out .= "📈 <strong>Business Path:</strong> There's a builder inside you! Start small or start small with freelancing. Read The Lean Startup—learn to take calculated risks.<br><br>";
 
    elseif (has($i,'law') || has($i,'lawyer') || has($i,'legal') || has($i,'clat') || has($i,'judge'))
        $out .= "⚖️ <strong>Law Path:</strong>Clear the CLAT exam for NALUs. Read the Newspaper daily, join debate clubs. Strong communication and logic will be your weapons.<br><br>";
 
    elseif (has($i,'teach') || has($i,'teacher') || has($i,'education') || has($i,'professor'))
        $out .= "📚 <strong>Teaching Path:</strong> After graduation, pursue a B.Ed. or start teaching on Unacademy/YouTube. There's a lot of scope in teaching!<br><br>";
 
    elseif (has($i,'science') || has($i,'research') || has($i,'physics') || has($i,'isro') || has($i,'space'))
        $out .= "🔬 <strong>Research Path:</strong> BSc → MSc → IISc or IIT. ISRO and DRDO are the best for research in India. Curiosity is your biggest tool!<br><br>";
 
    elseif (has($i,'music') || has($i,'singing') || has($i,'dance') || has($i,'acting') || has($i,'film'))
        $out .= "🎵 <strong>Arts Path:</strong> Explore FTII Pune or NSD Delhi. Start building your portfolio on YouTube/Instagram now – consistency builds an audience!
<br><br>";
 
    else
        $out .= "🌟 <strong>Explorer Mode:</strong> Not clear—that's normal! In 30 days, focus on 3 things: a coding tutorial, a design project, a business idea. Whatever feels exciting is the path!<br><br>";
 
    // Strength
    $out .= "💪 <strong>Your Strength</strong> (<em>$strengths</em>): ";
    if (has($strengths,'math') || has($strengths,'logical') || has($strengths,'analytical'))
        $out .= "Math/logic Engineering, Finance, Data Science are valuable courses to follow!";
    elseif (has($strengths,'communicat') || has($strengths,'talking') || has($strengths,'speaking'))
        $out .= "Communication Sales, Law, Teaching have gold – you have a rare gift!";
    elseif (has($strengths,'creative') || has($strengths,'imaginat') || has($strengths,'ideas'))
        $out .= "Creative Thinking Is in Sky-High Demand in Design, Content, Marketing!";
    elseif (has($strengths,'hardwork') || has($strengths,'dedicated') || has($strengths,'discipline'))
        $out .= "Hard work is the key to cracking any field – 80% of people lack this quality.!";
    else
        $out .= "In every field, there is a role that only a guy like you can play.!";
 
    // Weakness
    $out .= "<br><br>🔧 <strong>Weakness</strong> (<em>$weaknesses</em>): ";
    if (has($weaknesses,'procrastinat') || has($weaknesses,'lazy') || has($weaknesses,'delay'))
        $out .= "The Pomodoro Technique — 25 minutes of work + 5 minutes of break. You'll see a difference in a week.!";
    elseif (has($weaknesses,'nervous') || has($weaknesses,'anxious') || has($weaknesses,'fear'))
        $out .= "4-7-8 breathing + Mochak practice reduces nervousness by 90%.";
    elseif (has($weaknesses,'focus') || has($weaknesses,'distract') || has($weaknesses,'concentrat'))
        $out .= "Keep your phone in the other room while you study. Try the Forest app!";
    elseif (has($weaknesses,'confidence') || has($weaknesses,'shy') || has($weaknesses,'hesitat'))
        $out .= "Confidence grows through action—do one uncomfortable thing every day. 30 days!";
    else
        $out .= "Pick a weakness and work on it for 90 days – compound growth will happen!";
 
    // Confusion
    if (!empty(trim($confusion))) {
        $out .= "<br><br>🤔 <strong>Your Confusion</strong>: ";
        if (has($confusion,'parent') || has($confusion,'mummy') || has($confusion,'papa') || has($confusion,'force'))
            $out .= "Talk to parents with data—show salary reports and job scope. Logic works better than emotional arguments.💚";
        elseif (has($confusion,'science') || has($confusion,'commerce') || has($confusion,'stream'))
            $out .= "Science = max options. Commerce = business world. Arts = creativity/law. Interest se choose karo!";
        elseif (has($confusion,'neet') || has($confusion,'jee') || has($confusion,'tough'))
            $out .= "Those who consistently study 6-8 Harsha crack it. Consistency beats talent.!";
        elseif (has($confusion,'passion') || has($confusion,'no idea') || has($confusion,'confused'))
            $out .= "Whatever you do without drinking—that's your passion. Explore.!";
        else
            $out .= "\"<em>$confusion</em>\" — Thinking Seriously – Find and Message a Mentor on LinkedIn!";
    }
 
    // Class plan
    $cl = (int)$class;
    $out .= "<br><br>📅 <strong>Class $class Action Plan</strong>: ";
    if ($cl <= 10)     $out .= "Freely explore karo — coding, art, debate sab try karo. Board pressure abhi mat lo!";
    elseif ($cl <= 12) $out .= "Board + Entrance simultaneously. 5 target colleges shortlist karo aur deadlines track karo!";
    else               $out .= "Take internships from the second year onwards. Build a LinkedIn profile. Your portfolio is your real self.!";
 
    $out .= "<br><br>✨ <strong>SoulSpace Final Word:</strong> Not a perfect plan—just one <em>next step</em> -I want it. Get it today! 💚";
    return $out;
}
 
// ── FORM SUBMIT ───────────────────────────────────────────
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['interests'])) {
    $class = mysqli_real_escape_string($conn, $_POST['current_class']);
    $int   = trim(mysqli_real_escape_string($conn, $_POST['interests']));
    $str   = trim(mysqli_real_escape_string($conn, $_POST['strengths']));
    $weak  = trim(mysqli_real_escape_string($conn, $_POST['weaknesses'] ?? ''));
    $dream = trim(mysqli_real_escape_string($conn, $_POST['dream_career']));
    $conf  = trim(mysqli_real_escape_string($conn, $_POST['confusion'] ?? ''));
 
    if (!$int || !$str || !$dream)
        $errors[] = "Interests, strengths, and dream careers are important.!";
 
    if (empty($errors)) {
        $advice = generateAdvice($class, $int, $str, $weak, $dream, $conf);
        $adv_db = mysqli_real_escape_string($conn, $advice);
        $sql    = "INSERT INTO career_guidance
                    (user_id,current_class,interests,strengths,weaknesses,dream_career,confusion,advice_given)
                   VALUES('$user_id','$class','$int','$str','$weak','$dream','$conf','$adv_db')";
        if (mysqli_query($conn, $sql)) $submitted = true;
        else $errors[] = "DB Error: " . mysqli_error($conn);
    }
}
 
// Past guidance
$past = mysqli_query($conn,
    "SELECT * FROM career_guidance WHERE user_id='$user_id' ORDER BY created_at DESC LIMIT 5");
?>
