/* DATA FETCH */
$sql = "SELECT career_guidance.*, users.name 
        FROM career_guidance 
        JOIN users ON career_guidance.user_id = users.id
        ORDER BY career_guidance.created_at DESC";

$res = mysqli_query($conn, $sql);
?>

