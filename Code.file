 *RELATIONSHIP.php*
<?php
session_start();
if (!isset($_SESSION['user_id'])) { header("Location: auth.php?mode=login"); exit; }
 
$conn      = include 'db_career.php';
$user_id   = (int)$_SESSION['user_id'];
$full_name = htmlspecialchars($_SESSION['full_name']);
$advice    = "";
$submitted = false;
$errors    = [];
 
function has($text, $word) {
    return strpos(strtolower($text), $word) !== false;
}
 
function generateRelAdvice($type, $situation, $feeling, $tried) {
    $s   = strtolower($situation);
    $f   = strtolower($feeling);
    $out = "";
 
    // Type-based opening
    if ($type === 'friendship') {
        $out .= "👫 <strong>Friendship Advice:</strong> ";
        if (has($s,'fight') || has($s,'argument') || has($s,'angry') || has($s,'argument'))
            $out .= "Fights in friendships are normal — what matters is how you repair them. Give each other a day to cool down, then have a calm conversation without blame. Use 'I feel' statements instead of 'You always'. Strong friendships survive disagreements.<br><br>";
        elseif (has($s,'ignore') || has($s,'ghosting') || has($s,'stopped talking') || has($s,'distant'))
            $out .= "Being ignored by a friend hurts deeply. Before assuming the worst, check in with a simple, non-pressuring message. Sometimes people pull away because of their own struggles — it may not be about you at all. Give it time, but don't lose yourself waiting.<br><br>";
        elseif (has($s,'toxic') || has($s,'jealous') || has($s,'backstab') || has($s,'gossip'))
            $out .= "A toxic friendship drains you more than it builds you. Real friends celebrate your wins. If someone constantly puts you down or gossips about you, it's okay to slowly create distance. You don't owe anyone access to your life.<br><br>";
        else
            $out .= "Friendships go through phases — it's natural. Be honest about how you feel without being aggressive. A true friend will always make time to listen. If they don't, that itself tells you something important.<br><br>";
 
    } elseif ($type === 'romantic') {
        $out .= "💕 <strong>Romantic Advice:</strong> ";
        if (has($s,'crush') || has($s,'like someone') || has($s,'feelings') || has($s,'confess'))
            $out .= "Having feelings for someone is beautiful and nerve-wracking at the same time. You don't need to confess immediately — observe first. Are they kind? Do they respect people? If yes, a simple honest conversation is always better than overthinking. Rejection doesn't define you.<br><br>";
        elseif (has($s,'breakup') || has($s,'broke up') || has($s,'ex') || has($s,'heartbreak'))
            $out .= "Breakups hurt, and it's okay to grieve. Allow yourself to feel it — don't suppress it. But also remember: one relationship ending does not mean your story ends. Give yourself time, lean on trusted friends, and focus on rediscovering yourself. You are complete without someone else.<br><br>";
        elseif (has($s,'fight') || has($s,'argument') || has($s,'misunderstanding') || has($s,'distance'))
            $out .= "Every relationship has rough patches. The key is not to win the argument — it's to understand each other. Take a breath, listen actively, and speak without attacking. If both people are willing to try, most issues can be resolved with patience and honest communication.<br><br>";
        elseif (has($s,'cheating') || has($s,'cheat') || has($s,'trust') || has($s,'lied'))
            $out .= "Trust once broken is very hard to rebuild. Ask yourself honestly — can you forgive AND forget, or just forgive? Both are valid. But staying in a relationship that constantly hurts you is not love — it's habit. Choose yourself first, always.<br><br>";
        else
            $out .= "Romantic relationships thrive on communication, trust, and mutual respect. If something feels off, talk about it directly — assumptions create more damage than the actual problem. You deserve a relationship where you feel safe, heard, and valued.<br><br>";
 
    } elseif ($type === 'family') {
        $out .= "🏠 <strong>Family Advice:</strong> ";
        if (has($s,'parent') || has($s,'mum') || has($s,'dad') || has($s,'force') || has($s,'pressure'))
            $out .= "Parent pressure is one of the most common struggles for GenZ. Your parents love you — but sometimes their fears show up as control. Try having a calm, data-backed conversation about your choices. Show them you've thought it through. Most parents respond better to maturity than rebellion.<br><br>";
        elseif (has($s,'sibling') || has($s,'brother') || has($s,'sister') || has($s,'comparison'))
            $out .= "Sibling comparison is painful. Remember — you are not in competition with your sibling. Both of you are on different journeys. Talk to your parents calmly about how comparisons affect you. And to your sibling — they might also be dealing with pressure you don't see.<br><br>";
        elseif (has($s,'fight') || has($s,'argument') || has($s,'tense') || has($s,'home environment'))
            $out .= "A tense home environment is mentally exhausting. Try to identify a calm adult in the family you can confide in. If things are affecting your mental health seriously, speaking to a school counselor is always a brave and smart move.<br><br>";
        else
            $out .= "Family relationships are complex because they carry years of history. Pick the right time and right energy to have difficult conversations. Avoid reactive moments — plan when to speak and what to say. Progress in family dynamics is slow but always worth the effort.<br><br>";
 
    } elseif ($type === 'self') {
        $out .= "🧠 <strong>Self & Mental Health Advice:</strong> ";
        if (has($s,'lonely') || has($s,'alone') || has($s,'no friends') || has($s,'isolated'))
            $out .= "Feeling lonely doesn't mean you are unwanted — it means you haven't yet found your people. Join one new group, class, or online community related to something you love. Connections happen naturally when you're doing things that genuinely interest you.<br><br>";
        elseif (has($s,'anxious') || has($s,'anxiety') || has($s,'panic') || has($s,'overthinking'))
            $out .= "Anxiety is your brain trying to protect you from a threat that isn't always real. When you feel overwhelmed, try the 5-4-3-2-1 technique: name 5 things you see, 4 you hear, 3 you can touch, 2 you smell, 1 you taste. It brings you back to the present moment.<br><br>";
        elseif (has($s,'confidence') || has($s,'self-worth') || has($s,'not good enough') || has($s,'insecure'))
            $out .= "Low self-confidence is not a permanent trait — it's a habit that can be changed. Start small: write 3 things you did well each night. Confidence isn't about thinking you're perfect — it's about trusting yourself despite imperfections.<br><br>";
        elseif (has($s,'sad') || has($s,'depressed') || has($s,'cry') || has($s,'hopeless') || has($s,'empty'))
            $out .= "What you're feeling is real and valid. Please don't carry it alone. Talk to one trusted person — a friend, a teacher, or a family member. If it feels too heavy, reaching out to a counselor is a sign of strength, not weakness. You matter. 💚<br><br>";
        else
            $out .= "Taking time to understand yourself is one of the most powerful things you can do. Journaling, therapy, or simply talking to someone you trust can create enormous clarity. You are not your worst thoughts.<br><br>";
    } else {
        $out .= "🌟 <strong>General Advice:</strong> Every situation has a way through — even when it doesn't feel like it. The fact that you're seeking guidance shows real self-awareness. Be honest about what you need, ask for help without hesitation, and remember: most things that feel permanent are actually temporary.<br><br>";
    }
 
    // Feeling-based empathy
    $out .= "💙 <strong>About Your Feelings</strong> (<em>$feeling</em>): ";
    if (has($f,'hurt') || has($f,'pain') || has($f,'sad'))
        $out .= "Feeling hurt is a sign that you genuinely cared. Allow yourself to feel it — don't rush the healing process. Be gentle with yourself.";
    elseif (has($f,'angry') || has($f,'frustrated') || has($f,'mad'))
        $out .= "Anger is a valid emotion. But when it's hot, decisions made are usually ones we regret. Write it down first, then respond — never react in the heat of the moment.";
    elseif (has($f,'confused') || has($f,'lost') || has($f,'don\'t know'))
        $out .= "Confusion means you're at a crossroads — and that's actually a good place to be. It means you're thinking deeply. Give yourself permission to not have all the answers right now.";
    elseif (has($f,'anxious') || has($f,'scared') || has($f,'nervous'))
        $out .= "Fear of what might happen often hurts more than what actually happens. Focus on what you can control right now — not all the 'what ifs'.";
    elseif (has($f,'lonely') || has($f,'alone') || has($f,'empty'))
        $out .= "Loneliness is one of the hardest feelings. But it is temporary. Reach out to even one person today — a message, a call. Connection starts with a single step.";
    else
        $out .= "Whatever you're feeling right now — it's valid. You don't need to justify your emotions to anyone. Just make sure you're not carrying them alone.";
 
    // What you tried
    if (!empty(trim($tried))) {
        $out .= "<br><br>✅ <strong>What You've Already Tried:</strong> You mentioned — \"<em>$tried</em>\". That shows maturity and effort. Don't give up — sometimes the same action needs to be repeated calmly, or approached from a different angle. Progress in relationships is rarely linear.";
    }
 
    $out .= "<br><br>✨ <strong>SoulSpace Final Word:</strong> You are not alone in this. Every person you admire has gone through something similar. The fact that you're seeking help instead of giving up — that's already your strength. Keep going. 💚";
    return $out;
}
 
// Form submit
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['situation'])) {
    $type  = mysqli_real_escape_string($conn, $_POST['relationship_type']);
    $sit   = trim(mysqli_real_escape_string($conn, $_POST['situation']));
    $feel  = trim(mysqli_real_escape_string($conn, $_POST['feeling'] ?? ''));
    $tried = trim(mysqli_real_escape_string($conn, $_POST['what_tried'] ?? ''));
 
    if (!$sit) $errors[] = "Please describe your situation!";
 
    if (empty($errors)) {
        $advice = generateRelAdvice($type, $sit, $feel, $tried);
        $adv_db = mysqli_real_escape_string($conn, $advice);
        $sql    = "INSERT INTO relationship_help (user_id,relationship_type,situation,feeling,what_tried,advice_given)
                   VALUES('$user_id','$type','$sit','$feel','$tried','$adv_db')";
        if (mysqli_query($conn, $sql)) $submitted = true;
        else $errors[] = "DB Error: " . mysqli_error($conn);
    }
}
 
$past = mysqli_query($conn, "SELECT * FROM relationship_help WHERE user_id='$user_id' ORDER BY created_at DESC LIMIT 5");
?>
