<?php
// db_career.php — Database + Table create karta hai automatically
 
$conn = mysqli_connect('localhost', 'root', '', '');
if (!$conn) die("Connection failed: " . mysqli_connect_error());
 
// Database banana
mysqli_query($conn, "CREATE DATABASE IF NOT EXISTS soulspace");
mysqli_select_db($conn, 'soulspace');
mysqli_set_charset($conn, 'utf8');
 
// Users table
mysqli_query($conn, "CREATE TABLE IF NOT EXISTS users (
    id         INT AUTO_INCREMENT PRIMARY KEY,
    full_name  VARCHAR(100) NOT NULL,
    username   VARCHAR(50)  NOT NULL UNIQUE,
    email      VARCHAR(150) NOT NULL UNIQUE,
    password   VARCHAR(255) NOT NULL,
    age        INT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)");
 
// Career guidance table
mysqli_query($conn, "CREATE TABLE IF NOT EXISTS career_guidance (
    id            INT AUTO_INCREMENT PRIMARY KEY,
    user_id       INT NOT NULL,
    current_class VARCHAR(20),
    interests     TEXT,
    strengths     TEXT,
    weaknesses    TEXT,
    dream_career  VARCHAR(200),
    confusion     TEXT,
    advice_given  TEXT,
    created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
)");
 
// Sample data — sirf ek baar insert hoga
$check = mysqli_query($conn, "SELECT COUNT(*) as cnt FROM career_guidance");
$row   = mysqli_fetch_assoc($check);
if ($row['cnt'] == 0) {
    // Pehle ek sample user insert karo
    $hash = password_hash('test123', PASSWORD_DEFAULT);
    mysqli_query($conn, "INSERT IGNORE INTO users (full_name, username, email, password, age)
        VALUES ('Test Student', 'teststudent', 'test@soulspace.com', '$hash', 17)");
 
    $uid = mysqli_insert_id($conn);
    if ($uid > 0) {
        mysqli_query($conn, "INSERT INTO career_guidance
            (user_id, current_class, interests, strengths, weaknesses, dream_career, confusion, advice_given)
            VALUES
            ($uid, '12', 'coding aur web design', 'math aur logic', 'procrastination',
            'Software Engineer', 'science loon ya computer science',
            'Tech Path suggested — freeCodeCamp se shuru karo!')");
 
        mysqli_query($conn, "INSERT INTO career_guidance
            (user_id, current_class, interests, strengths, weaknesses, dream_career, confusion, advice_given)
            VALUES
            ($uid, '11', 'biology aur health', 'hardwork aur dedication', 'nervousness during exams',
            'Doctor', 'NEET bahut tough lagta hai',
            'Medical Path suggested — NCERT roz padho, consistency hi key hai!')");
    }
}
 
return $conn;
?>
 









 










 








