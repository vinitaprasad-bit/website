.past-item{padding:10px 0;border-bottom:1px solid var(--border)}
.past-item:last-child{border:none;padding-bottom:0}
.p-date{font-size:.71rem;color:var(--muted)}
.p-type{font-size:.8rem;font-weight:600;margin:3px 0;color:var(--pink)}
.p-snip{font-size:.77rem;color:var(--muted);line-height:1.4}
@media(max-width:800px){nav{padding:14px 18px}nav ul{display:none}.wrap{grid-template-columns:1fr;padding:100px 18px 50px}}
</style>
