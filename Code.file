<?php
$conn = mysqli_connect('localhost', 'root', '', '');
if (!$conn) die("Connection failed: " . mysqli_connect_error());
 
mysqli_query($conn, "CREATE DATABASE IF NOT EXISTS soulspace");
mysqli_select_db($conn, 'soulspace');
mysqli_set_charset($conn, 'utf8');
 
mysqli_query($conn, "CREATE TABLE  users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    username VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(150) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    age INT,
    gender ENUM('male','female','non-binary','prefer_not_to_say') DEFAULT 'prefer_not_to_say',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)");
 
mysqli_query($conn, "CREATE TABLE career_guidance (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT NOT NULL,
    current_class VARCHAR(20),
    interests TEXT,
    strengths TEXT,
    weaknesses TEXT,
    dream_career VARCHAR(200),
    confusion TEXT,
    advice_given TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
)");
 
mysqli_query($conn, "CREATE TABLE contact_messages (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    email VARCHAR(150) NOT NULL,
    message TEXT NOT NULL,
    sent_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)");
 
// Sample data ek baar
$row = mysqli_fetch_assoc(mysqli_query($conn, "SELECT COUNT(*) as cnt FROM users"));
if ($row['cnt'] == 0) {
    $hash = password_hash('test123', PASSWORD_DEFAULT);
    mysqli_query($conn, "INSERT INTO users (full_name,username,email,password,age)
        VALUES ('Test Student','teststudent','test@soulspace.com','$hash',17)");
    $uid = mysqli_insert_id($conn);
    mysqli_query($conn, "INSERT INTO career_guidance
        (user_id,current_class,interests,strengths,weaknesses,dream_career,confusion,advice_given)
        VALUES ($uid,'12','coding aur web design','math aur logic','procrastination',
        'Software Engineer','science loon ya CS','Tech Path suggested!')");
}
 
return $conn;
?>
 
