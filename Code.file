<script>
// Customizing the cursor
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top  = e.clientY + 'px';
});
document.querySelectorAll('a, button, .service-card').forEach(el => {
  el.addEventListener('mouseenter', () => cursor.classList.add('big'));
  el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
});
 
// Intersection reveal when you scroll down
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('visible');
  });
}, { threshold: 0.12 });
 
document.querySelectorAll('.reveal, .stat-item, .service-card, .testi-card, .step').forEach(el => {
  observer.observe(el);
});
 
// Mobile menu
function openMobile()  { document.getElementById('mobileMenu').classList.add('open'); }
function closeMobile() { document.getElementById('mobileMenu').classList.remove('open'); }
</script>

    </body>
</html>

*login.php*
<?php
session_start();
$conn = include 'dashboard.php';

if(isset($_POST['login'])){

    $email = $_POST['email'];
    $pass  = $_POST['password'];

    $res = mysqli_query($conn,"SELECT * FROM users WHERE email='$email'");

    if(mysqli_num_rows($res) > 0){
        $u = mysqli_fetch_assoc($res);

        if($pass == $u['password']){

            $_SESSION['user_id'] = $u['id'];
            $_SESSION['name'] = $u['name'];

            // 🔥 DIRECT DASHBOARD
            header("Location: dashboard.php");
            exit;

        } else {
            echo "Wrong password";
        }

    } else {

        mysqli_query($conn,"INSERT INTO users(name,email,password)
        VALUES('User','$email','$pass')");

        echo "Your account is created.Now login please.";
    }
}
?>

